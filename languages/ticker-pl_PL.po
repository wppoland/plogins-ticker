#. Plugin Name of the plugin
#: ticker.php
msgid "Ticker - Sales Countdown Timer for WooCommerce"
msgstr "Ticker - Zegar odliczający do końca promocji dla WooCommerce"

#. Plugin URI of the plugin
#: ticker.php
msgid "https://plogins.com/ticker/"
msgstr "https://plogins.com/ticker/"

#. Description of the plugin
#: ticker.php
msgid "Show a live sale countdown timer on WooCommerce product pages to create urgency and turn browsers into buyers."
msgstr "Wyświetlaj na żywo zegar odliczający do końca promocji na stronach produktów WooCommerce, aby budować poczucie pilności i zmieniać oglądających w kupujących."

#. Author of the plugin
#: ticker.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: ticker.php
msgid "https://plogins.com/"
msgstr "https://plogins.com/"

#: src/Admin/Settings.php:45
msgid "Ticker Settings"
msgstr "Ustawienia Ticker"

#: src/Admin/Settings.php:46
msgid "Ticker"
msgstr "Ticker"

#: src/Admin/Settings.php:78
msgid "WooCommerce sale end date"
msgstr "Data zakończenia promocji WooCommerce"

#: src/Admin/Settings.php:79
msgid "Fixed campaign end date"
msgstr "Stała data zakończenia kampanii"

#: src/Admin/Settings.php:90
msgid "Days : Hours : Minutes : Seconds"
msgstr "Dni : Godziny : Minuty : Sekundy"

#: src/Admin/Settings.php:91
msgid "Hours : Minutes : Seconds"
msgstr "Godziny : Minuty : Sekundy"

#: src/Admin/Settings.php:92
msgid "Hours : Minutes (compact)"
msgstr "Godziny : Minuty (kompaktowo)"

#: src/Admin/Settings.php:103
msgid "Product summary (below price)"
msgstr "Podsumowanie produktu (pod ceną)"

#: src/Admin/Settings.php:104
msgid "Before the add-to-cart form"
msgstr "Przed formularzem dodawania do koszyka"

#: src/Admin/Settings.php:105
msgid "After the add-to-cart form"
msgstr "Za formularzem dodawania do koszyka"

#: src/Admin/Settings.php:106
msgid "Product meta area"
msgstr "Obszar metadanych produktu"

#: src/Admin/Settings.php:125
msgid "Sale Countdown Timer"
msgstr "Zegar odliczający do końca promocji"

#: src/Admin/Settings.php:128
msgid "Create urgency with a live countdown"
msgstr "Buduj poczucie pilności dzięki odliczaniu na żywo"

#: src/Admin/Settings.php:129
msgid "Show a ticking countdown to the end of a sale on your product pages. The timer is calculated on the server and counted down in the browser — no layout shift, no jQuery."
msgstr "Wyświetlaj tykający zegar odliczający do końca promocji na stronach produktów. Zegar jest obliczany na serwerze i odliczany w przeglądarce — bez przesunięć układu, bez jQuery."

#: src/Admin/Settings.php:139
msgid "Enable countdown"
msgstr "Włącz odliczanie"

#: src/Admin/Settings.php:140
msgid "Countdown source"
msgstr "Źródło odliczania"

#: src/Admin/Settings.php:141
msgid "Campaign end date"
msgstr "Data zakończenia kampanii"

#: src/Admin/Settings.php:142
msgid "Heading"
msgstr "Nagłówek"

#: src/Admin/Settings.php:143
msgid "Time format"
msgstr "Format czasu"

#: src/Admin/Settings.php:144
msgid "Placement"
msgstr "Umiejscowienie"

#: src/Admin/Settings.php:145
msgid "Expired message"
msgstr "Komunikat po wygaśnięciu"

#: src/Admin/Settings.php:181
msgid "Show the sale countdown timer on single product pages."
msgstr "Wyświetlaj zegar odliczający do końca promocji na stronach pojedynczych produktów."

#: src/Admin/Settings.php:183
msgid "Master switch. When off, no countdown is rendered anywhere."
msgstr "Główny przełącznik. Po wyłączeniu odliczanie nie jest renderowane nigdzie."

#: src/Admin/Settings.php:198
msgid "Where the end time comes from. The sale date is read per product; the campaign date applies store-wide and is also used as a fallback when a product has no sale end date."
msgstr "Skąd pobierany jest czas zakończenia. Data promocji jest odczytywana dla każdego produktu; data kampanii obowiązuje w całym sklepie i jest też używana zastępczo, gdy produkt nie ma daty zakończenia promocji."

#. translators: %s: the site timezone string, e.g. Europe/Warsaw or UTC+2.
#: src/Admin/Settings.php:218
#, php-format
msgid "Interpreted in your site timezone (%s)."
msgstr "Interpretowane w strefie czasowej Twojej witryny (%s)."

#: src/Admin/Settings.php:238
msgid "e.g. Hurry — offer ends soon!"
msgstr "np. Pospiesz się — oferta wkrótce się kończy!"

#: src/Admin/Settings.php:240
msgid "Optional copy shown directly above the timer. Leave blank to show just the clock."
msgstr "Opcjonalny tekst wyświetlany bezpośrednio nad zegarem. Pozostaw puste, aby pokazać sam zegar."

#: src/Admin/Settings.php:255
msgid "How the remaining time is displayed. Compact hides seconds for a calmer look on long campaigns."
msgstr "Sposób wyświetlania pozostałego czasu. Tryb kompaktowy ukrywa sekundy, dla spokojniejszego wyglądu przy długich kampaniach."

#: src/Admin/Settings.php:270
msgid "Where the timer is inserted on the single product page."
msgstr "Gdzie zegar jest umieszczany na stronie pojedynczego produktu."

#: src/Admin/Settings.php:286
#: src/Service/CountdownService.php:144
msgid "This sale has ended."
msgstr "Ta promocja się zakończyła."

#: src/Admin/Settings.php:288
msgid "Shown in place of the clock once the countdown reaches zero. Leave blank for the default message."
msgstr "Wyświetlane zamiast zegara, gdy odliczanie osiągnie zero. Pozostaw puste, aby użyć domyślnego komunikatu."

#: templates/single-product/countdown.php:32
msgid "Sale countdown"
msgstr "Odliczanie do końca promocji"

#: templates/single-product/countdown.php:48
msgid "Sale ends in"
msgstr "Promocja kończy się za"

#: templates/single-product/countdown.php:52
msgid "days"
msgstr "dni"

#: templates/single-product/countdown.php:57
msgid "hrs"
msgstr "godz."

#: templates/single-product/countdown.php:62
msgid "min"
msgstr "min"

#: templates/single-product/countdown.php:67
msgid "sec"
msgstr "sek."

#: ticker.php:55
msgid "Ticker - Sales Countdown Timer for WooCommerce requires WooCommerce to be active."
msgstr "Ticker - Zegar odliczający do końca promocji dla WooCommerce wymaga aktywnej wtyczki WooCommerce."
